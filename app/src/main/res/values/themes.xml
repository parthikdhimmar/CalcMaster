<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.CalcMaster" parent="Theme.Material3.DayNight.NoActionBar">




        <item name="colorOnSecondary">@color/black</item>

    </style>






    <style name="WidgetButtonNumber">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:textColor">#FF000000</item>  <!-- Black text -->
        <item name="android:backgroundTint">@android:color/transparent</item>
    </style>

    <style name="WidgetButtonOperator">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">41dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:textColor">@color/orange</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
    </style>

    <style name="WidgetButtonEquals">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/orange</item>
    </style>

    <style name="Theme.CalcMaster" parent="Base.Theme.CalcMaster" />
</resources>