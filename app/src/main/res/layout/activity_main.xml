<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- Main Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraint_main_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:padding="16dp">


        <!-- Header with Navigation Tabs -->
        <HorizontalScrollView
            android:id="@+id/nav_scroll"
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:clipToPadding="false"
            android:padding="8dp"
            android:scrollbars="none"
            app:layout_constraintEnd_toStartOf="@id/menu_click_btn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/tab_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp"
                android:paddingEnd="20dp">

                <TextView

                    android:id="@+id/calculator_page1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="50dp"
                    android:background="@drawable/tab_background2"
                    android:fontFamily="@font/caudex"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Calculator"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/currencyPage_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/tab_background"
                    android:fontFamily="@font/caudex"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Exchange Rate"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/unit_converter_activity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/tab_background"
                    android:fontFamily="@font/caudex"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Unit Converter"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />


                <TextView
                    android:id="@+id/maths_question_activity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/tab_background"
                    android:fontFamily="@font/caudex"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Maths Game"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/rating_activity_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/tab_background"
                    android:fontFamily="@font/caudex"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Rating &amp; Feedback"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </HorizontalScrollView>



        <ImageButton
            android:id="@+id/menu_click_btn"
            android:layout_width="33dp"
            android:layout_height="33dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/circle_button"
            android:contentDescription="Menu"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_menu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <EditText
            android:id="@+id/input"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/input_background"
            android:fontFamily="@font/caudex"
            android:gravity="end|center_vertical"
            android:inputType="number"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:textColor="@color/white"
            android:textCursorDrawable="@drawable/cursor_color"
            android:textSize="36sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/nav_scroll" />

        <!-- Output Display -->
        <TextView
            android:id="@+id/output"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/caudex"
            android:gravity="end"
            android:paddingHorizontal="16dp"
            android:textColor="@color/accent"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/input" />

        <ImageButton
            android:id="@+id/history_btn"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/circle_button"
            android:contentDescription="History"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/vector_history"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.044"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/output"
            app:tint="@color/white" />

        <LinearLayout
            android:id="@+id/voice_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.055"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/history_btn">

            <ImageButton
                android:id="@+id/voice_btn"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="@drawable/circle_button"
                android:contentDescription="Voice Input"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_mic"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/stop_voice_btn"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/circle_button"
                android:contentDescription="Stop Voice"
                android:gravity="center"
                android:padding="7dp"
                android:text=""
                android:textColor="@color/white" />

        </LinearLayout>

        <GridLayout
            android:id="@+id/keyboard_BG"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:padding="8dp"
            android:rowCount="5"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/voice_controls">

            <!-- Row 1 -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/clear"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_operator"
                android:fontFamily="@font/castoro"
                android:text="C"
                android:textColor="@color/accent"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/percent"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_operator"
                android:fontFamily="@font/castoro"
                android:text="%"
                android:textColor="@color/accent"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/backspace"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_operator"
                android:fontFamily="@font/castoro"
                android:text="⌫"
                android:textColor="@color/accent"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/divide"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_operator"
                android:fontFamily="@font/castoro"
                android:text="÷"
                android:textColor="@color/accent"
                android:textSize="20sp" />

            <!-- Row 2 -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn7"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="7"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn8"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="8"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn9"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="9"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/multiply"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_operator"
                android:fontFamily="@font/castoro"
                android:text="×"
                android:textColor="@color/accent"
                android:textSize="20sp" />

            <!-- Row 3 -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn4"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="4"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn5"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="5"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn6"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="6"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/subtract"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_operator"
                android:fontFamily="@font/castoro"
                android:text="-"
                android:textColor="@color/accent"
                android:textSize="20sp" />

            <!-- Row 4 -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn1"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn2"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="2"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn3"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="3"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/add"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_operator"
                android:fontFamily="@font/castoro"
                android:text="+"
                android:textColor="@color/accent"
                android:textSize="20sp" />

            <!-- Row 5 -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn10"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="00"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn0"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDot"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_number"
                android:fontFamily="@font/castoro"
                android:text="."
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/equal"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_equal"
                android:fontFamily="@font/castoro"
                android:text="="
                android:textColor="@color/white"
                android:textSize="20sp" />
        </GridLayout>

        <!-- Options Menu -->
        <androidx.cardview.widget.CardView
            android:id="@+id/option_layout"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/nav_scroll">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/scientefic_calc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/vector_widget"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/white"
                    android:fontFamily="@font/caudex"
                    android:padding="5dp"
                    android:gravity="center_vertical"
                    android:text="Homescreen"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/theme_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/vector_theme"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/white"
                    android:fontFamily="@font/caudex"
                    android:padding="5dp"
                    android:gravity="center_vertical"

                    android:text="Theme"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/rating_Activity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/vector_language3"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/white"
                    android:fontFamily="@font/caudex"
                    android:padding="5dp"
                    android:gravity="center_vertical"

                    android:text="Language"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />


                <TextView
                    android:id="@+id/english_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="40dp"
                    android:fontFamily="@font/caudex"
                    android:padding="5dp"
                    android:text="English"
                    android:textColor="@color/white"
                    android:textSize="14sp" />


                <TextView
                    android:id="@+id/gujarati_converter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="40dp"
                    android:fontFamily="@font/caudex"
                    android:padding="5dp"
                    android:text="Gujarati"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/hindi_converter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="40dp"
                    android:fontFamily="@font/caudex"
                    android:padding="5dp"
                    android:text="Hindi"
                    android:textColor="@color/white"
                    android:textSize="14sp" />


            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/navigation_drawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/card_background">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:padding="16dp"
            app:layout_constraintBottom_toTopOf="@id/clear_btn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/clear_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/button_operator"
            android:fontFamily="@font/castoro"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Clear"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.drawerlayout.widget.DrawerLayout>