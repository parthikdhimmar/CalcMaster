<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="200dp"
    android:layout_height="270dp"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Display -->
    <TextView
        android:id="@+id/widget_display"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="5dp"
        android:background="#FFFFFFFF"
        android:ellipsize="end"
        android:gravity="end"
        android:fontFamily="@font/caudex"
        android:singleLine="true"
        android:text="0"
        android:textColor="#FF000000"
        android:textSize="20sp" />

    <!-- Buttons Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5">

    <!-- Row 1 -->
        <Button
            android:id="@+id/widget_clear"
            style="@style/WidgetButtonOperator"
            android:layout_columnSpan="2"
            android:fontFamily="@font/caudex"

            android:text="C" />

        <Button
            android:id="@+id/widget_backspace"
            style="@style/WidgetButtonOperator"
            android:fontFamily="@font/caudex"

            android:text="⌫" />

        <Button
            android:id="@+id/widget_divide"
            style="@style/WidgetButtonOperator"
            android:fontFamily="@font/caudex"

            android:text="÷" />

        <!-- Row 2 -->
        <Button
            android:id="@+id/widget_7"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="7" />

        <Button
            android:id="@+id/widget_8"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="8" />

        <Button
            android:id="@+id/widget_9"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="9" />

        <Button
            android:id="@+id/widget_multiply"
            style="@style/WidgetButtonOperator"
            android:fontFamily="@font/caudex"

            android:text="×" />

        <!-- Row 3 -->
        <Button
            android:id="@+id/widget_4"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="4" />

        <Button
            android:id="@+id/widget_5"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="5" />

        <Button
            android:id="@+id/widget_6"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="6" />

        <Button
            android:id="@+id/widget_subtract"
            style="@style/WidgetButtonOperator"
            android:fontFamily="@font/caudex"

            android:text="-" />

        <!-- Row 4 -->
        <Button
            android:id="@+id/widget_1"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="1" />

        <Button
            android:id="@+id/widget_2"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="2" />

        <Button
            android:id="@+id/widget_3"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="3" />

        <Button
            android:id="@+id/widget_add"
            style="@style/WidgetButtonOperator"
            android:fontFamily="@font/caudex"

            android:text="+" />

        <!-- Row 5 -->
        <Button
            android:id="@+id/widget_00"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="00" />

        <Button
            android:id="@+id/widget_0"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="0" />

        <Button
            android:id="@+id/widget_dot"
            style="@style/WidgetButtonNumber"
            android:fontFamily="@font/caudex"

            android:text="." />

        <Button
            android:id="@+id/widget_equals"
            style="@style/WidgetButtonEquals"
            android:fontFamily="@font/caudex"
            android:text="=" />
    </GridLayout>
</LinearLayout>
