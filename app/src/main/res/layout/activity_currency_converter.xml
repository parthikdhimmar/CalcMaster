<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp"
    tools:context=".currency_converter">

    <!-- Navigation Bar -->
    <HorizontalScrollView
        android:id="@+id/nav_scroll_page2"
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:clipToPadding="false"
        android:padding="8dp"
        android:paddingEnd="50dp"
        android:scrollbars="none"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="40dp"
            android:padding="4dp">

            <TextView
                android:id="@+id/calculator_page2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Calculator"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/currency_converter_activity_page2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background2"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Exchange Rate"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/unit_converter_activity_page2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Unit Converter"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />


            <TextView
                android:id="@+id/maths_question_activity_page2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Maths Game"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rating_activity_btn_page2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Rating &amp; Feedback"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Main Content Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/content_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nav_scroll_page2">

        <LinearLayout
            android:id="@+id/card_currency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Input Amount -->
            <EditText
                android:id="@+id/amountInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:fontFamily="@font/caudex"
                android:hint="Enter amount"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:textCursorDrawable="@drawable/cursor_color"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:textColorHint="@color/gray"
                android:textSize="18sp" />

            <!-- From Currency Spinner -->
            <Spinner
                android:id="@+id/fromCurrencySpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:gravity="start"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:spinnerMode="dropdown" />

            <!-- To Currency Spinner -->
            <Spinner
                android:id="@+id/toCurrencySpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:gravity="start"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:spinnerMode="dropdown" />

            <!-- Convert Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/convertButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_action"
                android:fontFamily="@font/caudex"
                android:text="Convert"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <!-- Result Text -->
            <TextView
                android:id="@+id/resultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/caudex"
                android:gravity="center"
                android:text="Result will be shown here"
                android:textColor="@color/accent"
                android:textSize="18sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Search Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/search_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="19dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/content_card">

        <LinearLayout
            android:id="@+id/card_currency2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Country Search Input -->
            <AutoCompleteTextView
                android:id="@+id/countrySearchInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:fontFamily="@font/caudex"
                android:hint="Enter country name"
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textCursorDrawable="@drawable/cursor_color"

                android:textColorHint="@color/gray"
                android:textStyle="bold"
                android:textSize="17sp" />

            <!-- Search Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/searchButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_action"
                android:fontFamily="@font/caudex"
                android:textStyle="bold"
                android:text="Search Currency"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <!-- Currency Result Text -->
            <TextView
                android:id="@+id/currencyResultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/caudex"
                android:gravity="center"
                android:text="Currency will be shown here"
                android:textColor="@color/accent"
                android:textSize="18sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>


</androidx.constraintlayout.widget.ConstraintLayout>