<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp"
    tools:context=".rating_feedback">

    <HorizontalScrollView
        android:id="@+id/nav_scroll_page5"
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:clipToPadding="false"
        android:padding="8dp"
        android:paddingEnd="50dp"
        android:scrollbars="none"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:paddingEnd="40dp">

            <TextView
                android:id="@+id/calculator_page5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Calculator"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/currency_converter_activity_page5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Exchange Rate"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/unit_converter_activity_page5"

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Unit Converter"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />


            <TextView
                android:id="@+id/maths_question_activity_page5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Maths Game"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rating_activity_btn_page5"

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background2"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Rating &amp; Feedback"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>
    </HorizontalScrollView>


    <TextView
        android:id="@+id/feedback_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/caudex"
        android:padding="8dp"
        android:text="Give Your Feedback !"
        android:textColor="@color/accent"
        android:textSize="22sp"
        app:layout_constraintBottom_toTopOf="@+id/content_card"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/nav_scroll_page5" />


    <!-- Content Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/content_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/nav_scroll_page5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/email_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/caudex"
                android:padding="5dp"
                android:text="sent email to"
                android:textColor="@color/accent"
                android:textSize="15sp" />

            <!-- User ID Text -->
            <TextView
                android:id="@+id/my_id_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/caudex"
                android:padding="1dp"
                android:text="moondhimmar@gmail.com"
                android:textColor="@color/accent"
                android:textSize="15sp" />

        </LinearLayout>


            <!-- User ID Input -->
            <EditText
                android:id="@+id/enter_user_Id"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"
                android:fontFamily="@font/caudex"
                android:hint="Your Id"
                android:textCursorDrawable="@drawable/cursor_color"

                android:inputType="textEmailAddress"
                android:paddingHorizontal="12dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gray"
                android:textSize="16sp" />

            <!-- Rating Bar -->
            <RatingBar
                android:id="@+id/ratingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:numStars="5"
                android:progressTint="@color/accent"
                android:secondaryProgressTint="@color/gray"
                android:stepSize="0.5" />

            <!-- Feedback Input -->
            <EditText
                android:id="@+id/feedbackEditText"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_background"
                android:fontFamily="@font/caudex"
                android:textCursorDrawable="@drawable/cursor_color"

                android:gravity="top"
                android:hint="Enter your feedback"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gray"
                android:textSize="16sp" />

            <!-- Send Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/sendButton"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_action"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:text="Send Rating"
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>