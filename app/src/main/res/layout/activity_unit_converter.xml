<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp"
    tools:context=".unit_converter">

    <!-- Navigation Bar -->
    <HorizontalScrollView
        android:id="@+id/nav_scroll_page3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:clipToPadding="false"
        android:padding="8dp"
        android:scrollbars="none"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">

            <TextView
                android:id="@+id/calculator_page3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Calculator"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/currency_converter_activity_page3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Exchange Rate"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/unit_converter_activity_page3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background2"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Unit Converter"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Centered items (visible by default) -->
            <TextView
                android:id="@+id/maths_question_activity_page3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Maths Game"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rating_activity_btn_page3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_background"
                android:fontFamily="@font/caudex"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Rating &amp; Feedback"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>
    <!-- Content Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/content_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nav_scroll_page3">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="3dp">

                <!-- Unit Selection Buttons -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:rowCount="2">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/Length_btn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:background="@drawable/button_action"
                        android:drawableTop="@drawable/vector_length"
                        android:drawableTint="@color/white"
                        android:fontFamily="@font/caudex"
                        android:padding="20dp"
                        android:text="Length"
                        android:textColor="@color/white"
                        android:textSize="11sp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/Area_btn"

                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:background="@drawable/button_action"
                        android:drawableTop="@drawable/vector_area"
                        android:drawableTint="@color/white"
                        android:fontFamily="@font/caudex"
                        android:padding="20dp"
                        android:text="Area"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/Volume_btn"

                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:background="@drawable/button_action"
                        android:drawableTop="@drawable/vector_volume"
                        android:drawableTint="@color/white"
                        android:fontFamily="@font/caudex"
                        android:padding="20dp"
                        android:text="Volume"
                        android:textColor="@color/white"
                        android:textSize="11sp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/Speed_btn"

                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:background="@drawable/button_action"
                        android:drawableTop="@drawable/vector_speed"
                        android:drawableTint="@color/white"
                        android:fontFamily="@font/caudex"
                        android:padding="20dp"
                        android:text="Speed"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/Weight_btn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:background="@drawable/button_action"
                        android:drawableTop="@drawable/vector_weight"
                        android:drawableTint="@color/white"
                        android:fontFamily="@font/caudex"
                        android:padding="20dp"
                        android:text="Weight"
                        android:textColor="@color/white"
                        android:textSize="11sp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/Time_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@drawable/button_action"
                        android:drawableTop="@drawable/vector_time"
                        android:drawableTint="@color/white"
                        android:fontFamily="@font/caudex"
                        android:padding="20dp"
                        android:paddingHorizontal="16dp"
                        android:text="Time"
                        android:textColor="@color/white"
                        android:textSize="12sp" />


                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/Temperature_btn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:background="@drawable/button_action"
                        android:drawableTop="@drawable/vector_temprature"
                        android:drawableTint="@color/white"
                        android:fontFamily="@font/caudex"
                        android:padding="20dp"
                        android:text="Temperature"
                        android:textColor="@color/white"
                        android:textSize="12sp" />
                </GridLayout>

                <!-- Time Button -->

                <!-- Length Conversion -->
                <LinearLayout
                    android:id="@+id/linear_length"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Spinner
                        android:id="@+id/fromLength"
                        android:layout_width="200dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="3dp"
                        android:background="@drawable/input_background"
                        android:padding="14dp"
                        android:spinnerMode="dropdown" />


                    <TextView
                        android:id="@+id/txt0"

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/caudex"
                        android:text="To"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/toLength"
                        android:layout_width="200dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"
                        android:padding="14dp"
                        android:spinnerMode="dropdown" />

                    <EditText
                        android:id="@+id/enter_from_length"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:hint="Enter value"
                        android:inputType="numberDecimal"
                        android:paddingStart="20dp"

                        android:textColor="@color/white"
                        android:textColorHint="@color/white"
                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/enter_to_length"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:inputType="none"
                        android:paddingStart="20dp"
                        android:textColor="@color/accent"

                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Area Conversion -->
                <LinearLayout
                    android:id="@+id/linear_area"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Spinner
                        android:id="@+id/fromArea"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"

                        android:background="@drawable/input_background"
                        android:padding="14dp"
                        android:spinnerMode="dropdown" />

                    <TextView
                        android:id="@+id/txt1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/caudex"
                        android:text="To"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/toArea"
                        android:layout_width="200dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"
                        android:padding="14dp"
                        android:spinnerMode="dropdown" />

                    <EditText
                        android:id="@+id/enter_from_area"
                        android:layout_width="270dp"
                        android:layout_height="48dp"

                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:hint="Enter value"
                        android:inputType="numberDecimal"
                        android:paddingStart="20dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white"
                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="17sp"

                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/enter_to_area"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:inputType="none"
                        android:paddingStart="20dp"
                        android:textColor="@color/accent"

                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Volume Conversion -->
                <LinearLayout
                    android:id="@+id/linear_volume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Spinner
                        android:id="@+id/fromVolume"
                        android:layout_width="200dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="3dp"

                        android:background="@drawable/input_background"
                        android:padding="14dp"
                        android:spinnerMode="dropdown" />


                    <TextView
                        android:id="@+id/txt2"

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/caudex"
                        android:text="To"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/toVolume"
                        android:layout_width="200dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"

                        android:background="@drawable/input_background"
                        android:padding="14dp"
                        android:spinnerMode="dropdown" />

                    <EditText
                        android:id="@+id/enter_from_volume"
                        android:layout_width="270dp"
                        android:layout_height="48dp"

                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:hint="Enter value"
                        android:inputType="numberDecimal"
                        android:paddingStart="20dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white"
                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="17sp"

                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/enter_to_volume"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:inputType="none"
                        android:paddingStart="20dp"
                        android:textColor="@color/accent"

                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Speed Conversion -->
                <LinearLayout
                    android:id="@+id/linear_speed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Spinner
                        android:id="@+id/fromSpeed"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:background="@drawable/input_background"
                        android:padding="10dp"
                        android:spinnerMode="dropdown" />

                    <TextView
                        android:id="@+id/txt3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/caudex"
                        android:text="To"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/toSpeed"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"
                        android:padding="13dp"
                        android:spinnerMode="dropdown" />

                    <EditText
                        android:id="@+id/enter_from_speed"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:hint="Enter value"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white"
                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/enter_to_speed"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:inputType="none"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/accent"
                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Weight Conversion -->
                <LinearLayout
                    android:id="@+id/linear_weight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Spinner
                        android:id="@+id/fromWeight"
                        android:layout_width="200dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="3dp"
                        android:background="@drawable/input_background"
                        android:padding="13dp"
                        android:spinnerMode="dropdown" />

                    <TextView
                        android:id="@+id/txt4"

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/caudex"
                        android:text="To"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/toWeight"
                        android:layout_width="200dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"

                        android:background="@drawable/input_background"
                        android:padding="13dp"
                        android:spinnerMode="dropdown" />

                    <EditText
                        android:id="@+id/enter_from_weight"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:hint="Enter value"
                        android:inputType="numberDecimal"
                        android:paddingStart="20dp"
                        android:textColor="@color/white"

                        android:textColorHint="@color/white"
                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="17sp"

                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/enter_to_weight"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:inputType="none"
                        android:paddingStart="20dp"
                        android:textColor="@color/accent"

                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Temperature Conversion -->
                <LinearLayout
                    android:id="@+id/linear_temperature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Spinner
                        android:id="@+id/fromTemperature"
                        android:layout_width="200dp"

                        android:layout_height="48dp"
                        android:layout_marginBottom="3dp"
                        android:background="@drawable/input_background"
                        android:padding="14dp"
                        android:spinnerMode="dropdown" />


                    <TextView
                        android:id="@+id/txt5"

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/caudex"
                        android:text="To"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/toTemperature"
                        android:layout_width="200dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"

                        android:background="@drawable/input_background"
                        android:padding="14dp"
                        android:spinnerMode="dropdown" />

                    <EditText
                        android:id="@+id/enter_from_temperature"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:hint="Enter value"
                        android:inputType="numberDecimal"
                        android:paddingStart="20dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white"


                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/enter_to_temprature"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:inputType="none"
                        android:paddingStart="20dp"
                        android:textColor="@color/accent"


                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Time Conversion -->
                <LinearLayout
                    android:id="@+id/linear_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Spinner
                        android:id="@+id/fromTime"
                        android:layout_width="200dp"

                        android:layout_height="48dp"
                        android:layout_marginBottom="3dp"
                        android:background="@drawable/input_background"
                        android:padding="14dp"
                        android:spinnerMode="dropdown" />


                    <TextView
                        android:id="@+id/txt6"

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/caudex"
                        android:text="To"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/toTime"
                        android:layout_width="200dp"
                        android:layout_height="48dp"

                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"
                        android:padding="14dp"
                        android:spinnerMode="dropdown" />

                    <EditText
                        android:id="@+id/enter_from_time"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:hint="Enter value"
                        android:inputType="numberDecimal"
                        android:paddingStart="20dp"
                        android:textColor="@color/white"

                        android:textColorHint="@color/white"
                        android:textCursorDrawable="@drawable/cursor_color"

                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/enter_to_time"
                        android:layout_width="270dp"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="@font/caudex"
                        android:inputType="none"
                        android:paddingStart="20dp"
                        android:textColor="@color/accent"

                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>


            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>